#!/usr/bin/env python3
import os
import sys

def main():
    search_dir = '.'
    output_file = "output.txt"

    args = sys.argv[1:]
    i = 0
    extensions = []
    while i < len(args):
        arg = args[i]
        if arg == '-d':
            if i + 1 >= len(args):
                print("Missing path after -d", file=sys.stderr)
                sys.exit(1)
            search_dir = args[i + 1]
            i += 2
        elif arg == '-o':
            if i + 1 >= len(args):
                print("Missing output file after -o", file=sys.stderr)
                sys.exit(1)
            output_file = args[i + 1]
            i += 2
        elif arg.startswith('-'):
            print(f"Unknown option: {arg}", file=sys.stderr)
            sys.exit(1)
        else:
            extensions.extend(args[i:])
            break

    if not extensions:
        print("Usage: list_files [-d <directory>] [-o <output_file>] <ext1> [ext2 ...]")
        print("       list_files -d /path .java .txt")
        sys.exit(1)

    normalized = []
    for e in extensions:
        e = e.strip()
        if not e.startswith('.'):
            e = '.' + e
        normalized.append(e)

    out_stream = sys.stdout
    if output_file:
        try:
            out_stream = open(output_file, 'w', encoding='utf-8')
        except Exception as e:
            print(f"Error opening output file {output_file}: {e}", file=sys.stderr)
            sys.exit(1)

    try:
        for root, dirs, files in os.walk(search_dir):
            for file in files:
                if any(file.endswith(ext) for ext in normalized):
                    full_path = os.path.join(root, file)
                    out_stream.write(full_path + '\n')
    except Exception as e:
        print(f"Error while walking directory {search_dir}: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        if output_file and out_stream is not sys.stdout:
            out_stream.close()

    ext_str = ', '.join(extensions)
    if output_file:
        print(f"List of files ({ext_str}) saved to {output_file}.")
    else:
        print(f"List of files ({ext_str}) printed to stdout.")

if __name__ == "__main__":
    main()