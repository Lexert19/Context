#!/usr/bin/env python3
import os
import sys

def main():
    show_path = False

    if len(sys.argv) < 2:
        print("Usage: context [-p] <file_extension>")
        print("       context [-p] \"ext1 ext2 ...\"")
        sys.exit(1)

    if sys.argv[1] == "-p":
        show_path = True
        if len(sys.argv) < 3:
            print("Missing extensions after -p")
            sys.exit(1)
        extensions_arg = sys.argv[2]
    else:
        extensions_arg = sys.argv[1]

    raw_extensions = extensions_arg.split()
    if not raw_extensions:
        print("No extensions provided.")
        sys.exit(1)

    extensions = []
    for e in raw_extensions:
        e = e.strip()
        if not e.startswith('.'):
            e = '.' + e
        extensions.append(e)

    output_file = "output.txt"

    with open(output_file, 'w', encoding='utf-8') as out_f:
        for root, dirs, files in os.walk('.'):
            for file in files:
                if any(file.endswith(ext) for ext in extensions):
                    path = os.path.join(root, file)
                    try:
                        with open(path, 'r', encoding='utf-8') as in_f:
                            if show_path:
                                out_f.write(f'"{path}"\n')
                            out_f.write(in_f.read())
                            out_f.write('\n')  # oddzielenie plików
                    except Exception as e:
                        print(f"Error reading {path}: {e}", file=sys.stderr)

    ext_str = ', '.join(raw_extensions)
    print(f"Content of files ({ext_str}) saved to {output_file}.")

if __name__ == "__main__":
    main()